# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Service Ports
ANALYSE_AGENT_PORT=4002
API_GATEWAY_PORT=4000
ANALYSE_ROUTER_PORT=4001

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=admin123
DB_NAME=ai

# MongoDB Configuration
MONGODB_URI=mongodb://mongodb:27017/analyse_agent
MONGODB_PORT=27017

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Application Settings
NODE_ENV=development
LOG_LEVEL=debug

# Security
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=24h

# API Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Cache Settings
CACHE_TTL=3600
CACHE_MAX_ITEMS=1000

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Service URLs (for internal communication)
ANALYSE_AGENT_URL=http://analyse_agent:4002
API_GATEWAY_URL=http://api_gateway:4000
ANALYSE_ROUTER_URL=http://analyse_router:4001 